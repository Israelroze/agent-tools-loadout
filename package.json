{
  "name": "agent-loadout",
  "displayName": "Agent Tools Loadout",
  "description": "Browse, preview, and equip AI agent instructions from Git repositories",
  "version": "0.1.3",
  "publisher": "Israelroze",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Israelroze/agent-tools-loadout"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "ai",
    "cursor",
    "copilot",
    "claude",
    "rules",
    "instructions",
    "prompts",
    "skills",
    "agents"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-loadout",
          "title": "Agent Tools Loadout",
          "icon": "$(package)"
        }
      ]
    },
    "views": {
      "agent-loadout": [
        {
          "id": "agentLoadoutBrowser",
          "name": "Content",
          "icon": "$(package)"
        }
      ]
    },
    "commands": [
      {
        "command": "agentLoadout.refresh",
        "title": "Agent Tools Loadout: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "agentLoadout.equip",
        "title": "Agent Tools Loadout: Load",
        "icon": "$(cloud-download)"
      },
      {
        "command": "agentLoadout.equipSelected",
        "title": "Agent Tools Loadout: Load Selected",
        "icon": "$(cloud-download)"
      },
      {
        "command": "agentLoadout.unequip",
        "title": "Agent Tools Loadout: Unequip",
        "icon": "$(trash)"
      },
      {
        "command": "agentLoadout.convert",
        "title": "Agent Tools Loadout: Convert"
      },
      {
        "command": "agentLoadout.preview",
        "title": "Agent Tools Loadout: Preview"
      },
      {
        "command": "agentLoadout.addSource",
        "title": "Agent Tools Loadout: Add Source",
        "icon": "$(add)"
      },
      {
        "command": "agentLoadout.removeSource",
        "title": "Agent Tools Loadout: Remove Source",
        "icon": "$(remove)"
      },
      {
        "command": "agentLoadout.search",
        "title": "Agent Tools Loadout: Search",
        "icon": "$(search)"
      },
      {
        "command": "agentLoadout.clearSearch",
        "title": "Agent Tools Loadout: Clear Search",
        "icon": "$(close)"
      },
      {
        "command": "agentLoadout.filterType",
        "title": "Agent Tools Loadout: Filter by Type",
        "icon": "$(filter)"
      },
      {
        "command": "agentLoadout.clearTypeFilter",
        "title": "Agent Tools Loadout: Clear Type Filter",
        "icon": "$(filter-filled)"
      },
      {
        "command": "agentLoadout.purgeCache",
        "title": "Agent Tools Loadout: Purge Cache"
      },
      {
        "command": "agentLoadout.setSensitivity",
        "title": "Agent Tools Loadout: Set Sensitivity"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentLoadout.equipSelected",
          "when": "view == agentLoadoutBrowser",
          "group": "navigation@1"
        },
        {
          "command": "agentLoadout.refresh",
          "when": "view == agentLoadoutBrowser",
          "group": "navigation@2"
        },
        {
          "command": "agentLoadout.search",
          "when": "view == agentLoadoutBrowser",
          "group": "navigation@3"
        },
        {
          "command": "agentLoadout.clearSearch",
          "when": "view == agentLoadoutBrowser && agentLoadout.searchActive",
          "group": "navigation@4"
        },
        {
          "command": "agentLoadout.filterType",
          "when": "view == agentLoadoutBrowser && !agentLoadout.typeFilterActive",
          "group": "navigation@5"
        },
        {
          "command": "agentLoadout.clearTypeFilter",
          "when": "view == agentLoadoutBrowser && agentLoadout.typeFilterActive",
          "group": "navigation@5"
        },
        {
          "command": "agentLoadout.addSource",
          "when": "view == agentLoadoutBrowser",
          "group": "navigation@6"
        },
        {
          "command": "agentLoadout.removeSource",
          "when": "view == agentLoadoutBrowser",
          "group": "navigation@7"
        }
      ],
      "view/item/context": [
        {
          "command": "agentLoadout.equip",
          "when": "view == agentLoadoutBrowser && viewItem =~ /^content$|^content-stale$/",
          "group": "inline"
        },
        {
          "command": "agentLoadout.preview",
          "when": "view == agentLoadoutBrowser && viewItem =~ /^content/"
        },
        {
          "command": "agentLoadout.equip",
          "when": "view == agentLoadoutBrowser && viewItem =~ /^content/"
        },
        {
          "command": "agentLoadout.removeSource",
          "when": "view == agentLoadoutBrowser && viewItem == source"
        }
      ],
      "commandPalette": [
        {
          "command": "agentLoadout.unequip"
        },
        {
          "command": "agentLoadout.convert"
        },
        {
          "command": "agentLoadout.removeSource"
        },
        {
          "command": "agentLoadout.purgeCache"
        },
        {
          "command": "agentLoadout.setSensitivity"
        }
      ]
    },
    "configuration": {
      "title": "Agent Tools Loadout",
      "properties": {
        "agentLoadout.sources": {
          "type": "array",
          "scope": "machine",
          "default": [],
          "description": "Array of Git repository sources to scan for instruction content",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "repo"
                ],
                "description": "Source type (currently only 'repo' is supported)"
              },
              "url": {
                "type": "string",
                "description": "Git repository URL (HTTPS or SSH)"
              },
              "branch": {
                "type": "string",
                "description": "Branch to clone (leave empty for default)"
              },
              "path": {
                "type": "string",
                "description": "Subdirectory to scan (leave empty for repo root)"
              },
              "name": {
                "type": "string",
                "description": "Display name for this source"
              }
            },
            "required": [
              "type",
              "url"
            ]
          }
        },
        "agentLoadout.defaultAgent": {
          "type": "string",
          "scope": "machine",
          "enum": [
            "copilot",
            "cursor",
            "claude"
          ],
          "default": "cursor",
          "description": "Default target agent when equipping content"
        },
        "agentLoadout.sensitivity": {
          "type": "string",
          "scope": "machine",
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "enumDescriptions": [
            "Show almost all files with matching extensions — minimal filtering",
            "Require at least one structural signal (known directory, frontmatter, or filename pattern)",
            "Require strong signals (frontmatter type field + content heuristics)"
          ],
          "default": "low",
          "description": "Controls how strictly files must match agent instruction patterns to appear in the browser"
        }
      }
    }
  },
  "scripts": {
    "build:vsix": "node scripts/build-vsix.js",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vscode-test",
    "vscode:prepublish": "npm run package"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.13.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  }
}
